# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:root@localhost:5432/dt_crm

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# When behind nginx/Caddy/cloud LB (X-Forwarded-* headers): set to number of proxies, usually 1
# TRUST_PROXY_HOPS=1

# ─── JWT (generate with: openssl rand -hex 32) ───────────────────────────────
JWT_ACCESS_SECRET=change-me-to-a-random-32-char-or-longer-string
JWT_ACCESS_EXPIRES=30d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Use * for dev, or comma-separated origins for prod
CORS_ORIGIN=http://localhost:5173

# ─── Google Ads Webhook ───────────────────────────────────────────────────────
# Set in Google Ads console under Lead Form Extensions > Webhook
# Leave empty to skip signature verification in dev
GOOGLE_ADS_WEBHOOK_SECRET=

# ─── SMTP (optional — if absent, reset emails are logged to console) ──────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@dextora.com

# ─── App URL (used in password reset emails) ─────────────────────────────────
APP_URL=http://localhost:3000

# ─── Logging ──────────────────────────────────────────────────────────────────
# Levels: debug | info | warn | error. Default: info (warn in tests).
LOG_LEVEL=info
# Output format: text (human readable, default) | json (one JSON object per line)
LOG_FORMAT=text

# ─── Calling agent (Vobiz telephony + Gemini Live) ───────────────────────────
# Public HTTPS base — Vobiz dials this back for answer/hangup webhooks. Use
# `ngrok http <PORT>` for local dev and paste the https URL here.
PUBLIC_BASE_URL=

# Bun WebSocket port for /voice-stream. Leave unset to disable the agent.
WS_PORT=8088

# Local artifacts root. Served at /recordings/{batchId}/{itemId}/recording.mp3
ARTIFACTS_DIR=./call-artifacts

# Gemini AI keys + model selection (Live = real-time audio; text = analysis)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LIVE_MODEL=gemini-2.5-flash-preview-native-audio-dialog
GEMINI_VOICE_NAME=Puck
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Vobiz (telephony provider, Plivo-compatible)
VOBIZ_AUTH_ID=
VOBIZ_AUTH_TOKEN=
VOBIZ_PHONE_NUMBER=
VOBIZ_RING_TIMEOUT=30
VOBIZ_TIME_LIMIT=600
VOBIZ_RECORDING_TIME_LIMIT=900
VOBIZ_RECORDING_FORMAT=mp3
VOBIZ_RECORDING_CHANNELS=stereo
VOBIZ_MACHINE_DETECTION=false
