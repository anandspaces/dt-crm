{
	"name": "express-server",
	"module": "src/index.ts",
	"type": "module",
	"scripts": {
		"start": "bun run src/index.ts",
		"dev": "bun --hot src/index.ts",
		"lint": "biome lint .",
		"format": "biome format . --write",
		"check": "biome check .",
		"check:fix": "biome check . --write",
		"db:generate": "drizzle-kit generate --config drizzle/drizzle.config.ts",
		"db:migrate": "drizzle-kit migrate --config drizzle/drizzle.config.ts",
		"db:test:setup": "bun --env-file .env.test tests/setup.ts",
		"test": "bun test --env-file .env.test",
		"test:unit": "bun test --env-file .env.test tests/unit",
		"test:e2e": "bun test --env-file .env.test tests/e2e",
		"test:watch": "bun test --env-file .env.test --watch",
		"test:coverage": "bun test --env-file .env.test --coverage",
		"test:ci": "bun test --env-file .env.test --bail"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@types/bun": "latest",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/multer": "^2.1.0",
		"@types/nodemailer": "^8.0.0",
		"@types/supertest": "^7.2.0",
		"@types/ws": "^8.18.1",
		"drizzle-kit": "^0.31.10",
		"supertest": "^7.2.2"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@google/genai": "^2.3.0",
		"bcryptjs": "^3.0.3",
		"cors": "^2.8.6",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"express": "^5.2.1",
		"express-rate-limit": "^8.5.1",
		"helmet": "^8.1.0",
		"jsonwebtoken": "^9.0.3",
		"multer": "^2.1.1",
		"nodemailer": "^8.0.7",
		"postgres": "^3.4.9",
		"uuid": "^14.0.0",
		"ws": "^8.20.1",
		"zod": "^4.4.3"
	}
}
