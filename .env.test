NODE_ENV=test

DATABASE_URL=postgresql://postgres:root@localhost:5432/dt_crm_test

JWT_ACCESS_SECRET=test-secret-that-is-at-least-32-characters-long
JWT_ACCESS_EXPIRES=15m

CORS_ORIGIN=*

GOOGLE_ADS_WEBHOOK_SECRET=test-google-webhook-secret

SMTP_HOST=
SMTP_FROM=noreply@test.local
APP_URL=http://localhost:3000

# Quieter logs in tests; warnings + errors still surface.
LOG_LEVEL=warn

# ─── Calling agent (test stubs) ──────────────────────────────────────────────
# These are NOT real credentials. Tests mock `fetch` so no live call is placed.
PUBLIC_BASE_URL=http://localhost:3000
VOBIZ_AUTH_ID=test-vobiz-auth-id
VOBIZ_AUTH_TOKEN=test-vobiz-auth-token
VOBIZ_PHONE_NUMBER=+91-test-from
# GEMINI_API_KEY intentionally unset — gemini services fall back to zero-analysis.
ARTIFACTS_DIR=./tmp/test-artifacts
